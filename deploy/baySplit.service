[Unit]
Description=Bay Split FastAPI Service
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/baySplit
Environment="PATH=/var/www/baySplit/venv/bin"
Environment="ROOT_PATH=/baySplit"
ExecStart=/var/www/baySplit/venv/bin/gunicorn -k uvicorn.workers.UvicornWorker -w 2 -b 127.0.0.1:8003 app.main:app
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=baySplit

[Install]
WantedBy=multi-user.target
